// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  phone      String
  password   String
  address    String?
  role       Role
  avatar     String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  donors   Donors?
  hospital Hospital?
}

model Donors {
  id           Int       @id @default(autoincrement())
  bloodType    String
  lastDonation DateTime?
  latitude     Float?
  longitude    Float?
  weight       Float?
  unitBlood    Int?
  status       Status    @default(UNAVAILABLE)
  responseRate Decimal   @default(0) @db.Decimal(5, 2)
  userId       Int       @unique
  user         User      @relation(fields: [userId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  donorNotifications Notification[] @relation("DonorNotifications")
}

model Hospital {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  licenseCode String?
  pathFile    String?
  latitude    Float?
  longitude   Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  hospitalNotifications Notification[] @relation("HospitalNotifications")
}

model Notification {
  id              Int      @id @default(autoincrement())
  donorId         Int
  hospitalId      Int
  hospitalName    String
  hospitalAddress String?
  distance        Float
  urgency         Int
  notes           String?
  isAccept        Boolean?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  donor    Donors   @relation("DonorNotifications", fields: [donorId], references: [id])
  hospital Hospital @relation("HospitalNotifications", fields: [hospitalId], references: [id])
}

enum Role {
  ADMIN
  DONOR
  REQUESTER
}

enum Status {
  AVAILABLE
  UNAVAILABLE
}
